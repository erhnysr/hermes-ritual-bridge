# Copy to .env and fill in. Never commit .env.

# ===== Chain Connection (Ritual Chain, ID 1979) =====
# https://docs.ritualfoundation.org
RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# ===== Deployer / agent account =====
PRIVATE_KEY=0x...

# ===== Contract Verification (Ritual custom verifier) =====
RITUAL_VERIFIER_URL=https://rpc.ritualfoundation.org/api/verify

# ===== Deployed contract (filled in after running scripts/deploy.ts) =====
CONSUMER_ADDRESS=

# ===== Optional overrides for scripts/request-inference.ts =====
# A registered TEE executor with LLM capability. If unset, the script
# auto-discovers one from the TEEServiceRegistry.
EXECUTOR_ADDRESS=
# Prompt to send. Defaults to a short test prompt if unset.
PROMPT=
