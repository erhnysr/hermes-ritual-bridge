{
  "name": "hermes-ritual-bridge",
  "version": "0.1.0",
  "description": "Solidity bridge from a Hermes AI agent to Ritual Chain's native LLM precompile (0x0802) for on-chain inference",
  "license": "MIT",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "node": "hardhat node",
    "deploy": "hardhat run scripts/deploy.ts",
    "request": "hardhat run scripts/request-inference.ts",
    "lint": "solhint 'contracts/**/*.sol'",
    "clean": "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.6.1",
    "hardhat": "^2.22.0",
    "solhint": "^5.0.0",
    "typescript": "^5.4.0"
  }
}
